{
    "unusedString":
        "
            #include "/lib/settings.glsl"
        ",
    "version": 1,
    "excludeLodsFromVanillaDepth": true,
    "opaqueDrawBuffers": [
        1,
        2,
        3
    ],
    "translucentDrawBuffers": [
        8
    ],
    "blending": {
        -1 : "off",
        0 : "ONE ONE_MINUS_SRC_ALPHA ONE ONE_MINUS_SRC_ALPHA"
    },
#ifdef TAAU
    "taaOffset": "{ vec2 j = fract(vec2(0.7548776662466927, 0.5698402909980532) * float(frameCounter % 64 + 1)) - 0.5; return j * refraxJitterScale; }",
#elif defined TEMPORAL_AA
    "taaOffset": "{ vec2 h[8] = vec2[8](vec2(0.5000, 0.3333), vec2(0.2500, 0.6667), vec2(0.7500, 0.1111), vec2(0.1250, 0.4444), vec2(0.6250, 0.7778), vec2(0.3750, 0.2222), vec2(0.8750, 0.5556), vec2(0.0625, 0.8889)); return (h[frameCounter % 8] - 0.5) * refraxJitterScale; }",
#endif
    "uniforms": [
        "gbufferModelViewInverse",
        "cameraPosition",
        "frameTimeCounter",
        "rainStrength",
        "frameCounter",
        "far",
        "refraxViewSize",
        "refraxSunDir",
        "refraxLightDir",
        "refraxJitterScale"
    ],
    "samplers": []
}
