{
    "unusedString":
        "
            #include "/lib/settings.glsl"
        ",
    "version": 1,
    "excludeLodsFromVanillaDepth": true,
    "opaqueDrawBuffers": [
        1,
        2,
        3
    ],
    "translucentDrawBuffers": [
        8,
        9
    ],
    "blending": {
        -1 : "off",
        0 : "ONE ONE_MINUS_SRC_ALPHA ONE ONE_MINUS_SRC_ALPHA",
        1 : "off"
    },
#ifdef TAAU
    "taaOffset": "{ vec2 j = fract(vec2(0.7548776662466927, 0.5698402909980532) * float(refraxFrameCounter % 64 + 1)) - 0.5; return j * refraxJitterScale; }",
#elif defined TEMPORAL_AA
    "taaOffset": "{ vec2 h[8] = vec2[8](vec2(0.5000, 0.3333), vec2(0.2500, 0.6667), vec2(0.7500, 0.1111), vec2(0.1250, 0.4444), vec2(0.6250, 0.7778), vec2(0.3750, 0.2222), vec2(0.8750, 0.5556), vec2(0.0625, 0.8889)); return (h[refraxFrameCounter % 8] - 0.5) * refraxJitterScale; }",
#endif
    "uniforms": [
        "rainStrength",
        "refraxViewSize",
        "refraxSunDir",
        "refraxLightDir",
        "refraxJitterScale",
        "refraxFrameCounter",
        "refraxFrameTimeCounter",
        "refraxFar",
        "refraxCameraPosition",
        "refraxModelViewInv0",
        "refraxModelViewInv1",
        "refraxModelViewInv2",
        "refraxModelViewInv3",
        "refraxVxProjInv0",
        "refraxVxProjInv1",
        "refraxVxProjInv2",
        "refraxVxProjInv3"
    ],
    "samplers": [
        "vxDepthTexOpaque"
    ]
}
